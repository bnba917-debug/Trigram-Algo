PORT=3000

# 生产环境务必修改为强口令（建议 16 位以上，含大小写/数字/符号）
ADMIN_PASSWORD=请替换为强口令

# 生产环境必须为 false；本地调试可设 true
DEBUG_UNLOCK=false

# AI 提供商: kimi | openai
AI_PROVIDER=kimi

# Kimi API Key（https://platform.moonshot.cn/console/api-keys）
AI_API_KEY=

# 国内节点；海外改为 https://api.moonshot.ai/v1
AI_API_BASE=https://api.moonshot.cn/v1

# 推荐: kimi-k2.6（玄学文案）| moonshot-v1-8k（经济）
AI_MODEL=kimi-k2.6
