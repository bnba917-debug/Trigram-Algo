# 生产环境 .env 示例 — 复制到项目根目录并重命名为 .env
# cp deploy/env.production.example .env

PORT=3000

# 务必修改为强口令（16 位以上）
ADMIN_PASSWORD=请替换为强口令

# 生产环境必须为 false
DEBUG_UNLOCK=false

AI_PROVIDER=kimi
AI_API_KEY=sk-你的Kimi密钥

# 国内节点
AI_API_BASE=https://api.moonshot.cn/v1
AI_MODEL=kimi-k2.6

# SSL 证书（Let's Encrypt）— 填写后 deploy 时自动申请 HTTPS
SSL_EMAIL=你的邮箱@example.com
# DOMAIN=aigo.toppeertalk.com
